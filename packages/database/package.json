{
  "name": "@minh-di-dau-the/database",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma schema and database client for Mình Đi Đâu Thế",
  "main": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.1.3"
  }
}
