generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Profiles ───────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String?      // Nullable to support future Social Auth
  name          String?
  avatarUrl     String?
  healthProfile String?      // JSON string: allergies, motion sickness, etc.
  provider      String       @default("local") // "local", "google", "facebook"
  providerId    String?      // External provider user ID
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tripMembers              TripMember[]
  refreshTokens            RefreshToken[]
  proposedItineraryChanges ItineraryProposal[]  @relation("ProposalProposer")
  reviewedItineraryChanges ItineraryProposal[]  @relation("ProposalReviewer")
  createdVoteSessions      VoteSession[]        @relation("VoteSessionCreator")
  approvedVoteSessions     VoteSession[]        @relation("VoteSessionApprover")
  publishedTemplates       CommunityTemplate[]  @relation("TemplatePublisher")
  voteBallots              VoteBallot[]
  reunionInviteDeliveries  ReunionInviteDelivery[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Trip Management ───────────────────────────────

model Trip {
  id          String       @id @default(cuid())
  name        String
  destination String
  startDate   DateTime
  endDate     DateTime
  joinCode    String       @unique // Shareable link code
  timeZone    String       @default("Asia/Ho_Chi_Minh")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members              TripMember[]
  itineraryItems       ItineraryItem[]
  itineraryProposals   ItineraryProposal[]
  voteSessions         VoteSession[]
  voteSessionOutcomes  VoteSessionOutcome[]
  communityTemplates   CommunityTemplate[]
  logisticsUnits       LogisticsUnit[]
  allocationAssignments AllocationAssignment[]
  checklistGroups      ChecklistGroup[]
  checklistItems       ChecklistItem[]
  attendanceSessions   AttendanceSession[]
  tripFund             TripFund?
  fundContributions    FundContribution[]
  fundExpenses         FundExpense[]
  safetyDirectoryEntries SafetyDirectoryEntry[]
  safetyAlerts         SafetyAlert[]
  bookingImportDrafts  BookingImportDraft[]
  dailyPodcastRecaps   DailyPodcastRecap[]
  vaultDocuments       VaultDocument[]
  feedbackPoll         TripFeedbackPoll?
  anonymousFeedbackSubmissions AnonymousFeedbackSubmission[]
  feedbackSubmissionReceipts   FeedbackSubmissionReceipt[]
  reunionInvite        ReunionInvite?
}

enum TripRole {
  LEADER
  MEMBER
}

model TripMember {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  role      TripRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  logisticsAssignments        AllocationAssignment[] @relation("AssignedMember")
  createdLogisticsAssignments AllocationAssignment[] @relation("AssignmentCreator")
  assignedChecklistItems      ChecklistItem[]        @relation("AssignedChecklistItems")
  createdAttendanceSessions   AttendanceSession[]    @relation("AttendanceSessionCreator")
  attendanceSubmissions       AttendanceSubmission[] @relation("AttendanceSubmissionMember")
  ownedFunds                  TripFund[]             @relation("TripFundOwner")
  submittedFundContributions  FundContribution[]     @relation("FundContributionMember")
  confirmedFundContributions  FundContribution[]     @relation("FundContributionConfirmer")
  createdFundExpenses         FundExpense[]          @relation("FundExpenseCreator")
  createdSafetyAlerts         SafetyAlert[]          @relation("SafetyAlertCreator")
  acknowledgedSafetyAlerts    SafetyAlert[]          @relation("SafetyAlertAcknowledger")
  createdBookingImportDrafts  BookingImportDraft[]   @relation("BookingImportDraftCreator")
  reviewedBookingImportDrafts BookingImportDraft[]   @relation("BookingImportDraftReviewer")
  uploadedVaultDocuments      VaultDocument[]        @relation("VaultDocumentUploader")
  reviewedVaultDocuments      VaultDocument[]        @relation("VaultDocumentReviewer")
  feedbackSubmissionReceipts  FeedbackSubmissionReceipt[]
  reunionAvailabilities       ReunionAvailability[]

  @@unique([userId, tripId])
}

model ReunionInvite {
  id                   String   @id @default(cuid())
  tripId               String   @unique
  status               String   @default("PENDING_SEND")
  title                String
  message              String
  suggestedDateOptions String[]
  recommendedDate      String?
  finalizedDate        String?
  unlockedAt           DateTime
  sentAt               DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  trip          Trip                    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  availabilities ReunionAvailability[]
  deliveries    ReunionInviteDelivery[]
}

model ReunionAvailability {
  id              String   @id @default(cuid())
  reunionInviteId String
  tripMemberId    String
  selectedDates   String[]
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reunionInvite ReunionInvite @relation(fields: [reunionInviteId], references: [id], onDelete: Cascade)
  tripMember     TripMember    @relation(fields: [tripMemberId], references: [id], onDelete: Cascade)

  @@unique([reunionInviteId, tripMemberId])
}

model ReunionInviteDelivery {
  id              String   @id @default(cuid())
  reunionInviteId String
  userId          String
  recipientEmail  String
  status          String   @default("PENDING")
  subjectLine     String
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reunionInvite ReunionInvite @relation(fields: [reunionInviteId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reunionInviteId, userId])
}

enum FeedbackPollStatus {
  LOCKED
  OPEN
  CLOSED
}

model TripFeedbackPoll {
  id        String             @id @default(cuid())
  tripId     String             @unique
  status     FeedbackPollStatus @default(LOCKED)
  openedAt   DateTime?
  closedAt   DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  trip                     Trip                          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  submissions              AnonymousFeedbackSubmission[]
  submissionReceipts       FeedbackSubmissionReceipt[]
}

model AnonymousFeedbackSubmission {
  id           String   @id @default(cuid())
  tripId       String
  pollId       String
  moodScore    Int
  highlight    String
  wishNextTime String
  createdAt    DateTime @default(now())

  trip  Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  poll  TripFeedbackPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  receipt FeedbackSubmissionReceipt?

  @@index([tripId, createdAt])
}

model FeedbackSubmissionReceipt {
  id           String   @id @default(cuid())
  tripId       String
  pollId       String
  tripMemberId String
  submissionId String   @unique
  submittedAt  DateTime @default(now())

  trip        Trip                      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  poll        TripFeedbackPoll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  tripMember  TripMember                @relation(fields: [tripMemberId], references: [id], onDelete: Cascade)
  submission  AnonymousFeedbackSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([pollId, tripMemberId])
}

enum VaultDocumentKind {
  ID_CARD
  PASSPORT
  FLIGHT_TICKET
  HOTEL_BOOKING
  OTHER
}

enum VaultDocumentStatus {
  PENDING_REVIEW
  READY_FOR_CHECK_IN
  ARCHIVED
}

model VaultDocument {
  id                     String              @id @default(cuid())
  tripId                 String
  uploadedByTripMemberId String
  reviewedByTripMemberId String?
  kind                   VaultDocumentKind
  status                 VaultDocumentStatus @default(PENDING_REVIEW)
  fileName               String
  mimeType               String
  fileUrl                String
  note                   String?
  expiresAt              DateTime
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  trip        Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploadedBy  TripMember  @relation("VaultDocumentUploader", fields: [uploadedByTripMemberId], references: [id], onDelete: Cascade)
  reviewedBy  TripMember? @relation("VaultDocumentReviewer", fields: [reviewedByTripMemberId], references: [id])

  @@index([tripId, status])
  @@index([tripId, uploadedByTripMemberId])
}

enum BookingImportDraftStatus {
  DRAFT
  CONFIRMED
  REJECTED
}

model BookingImportDraft {
  id                     String                   @id @default(cuid())
  tripId                 String
  createdByTripMemberId  String?
  reviewedByTripMemberId String?
  sourceChannel          String
  forwardingAddress      String
  sourceMessageId        String?
  sourceSender           String?
  sourceSubject          String?
  rawContent             String
  confidenceLabel        String
  status                 BookingImportDraftStatus @default(DRAFT)
  parseSummary           String
  parsedItems            Json
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy  TripMember? @relation("BookingImportDraftCreator", fields: [createdByTripMemberId], references: [id])
  reviewedBy TripMember? @relation("BookingImportDraftReviewer", fields: [reviewedByTripMemberId], references: [id])

  @@index([tripId, status])
}

// ─── Itinerary ─────────────────────────────────────

model ItineraryItem {
  id              String    @id @default(cuid())
  tripId          String
  dayIndex        Int
  sortOrder       Int
  startMinute     Int?
  title           String
  locationName    String?
  locationAddress String?
  placeId         String?
  lat             Float?
  lng             Float?
  shortNote       String?
  version         Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trip      Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  proposals ItineraryProposal[] @relation("ProposalTargetItem")
  voteSessionsAsTarget   VoteSession[]        @relation("VoteSessionTargetItem")
  voteOutcomesAsTarget   VoteSessionOutcome[] @relation("VoteOutcomeTargetItem")
  voteOutcomesAsCreated  VoteSessionOutcome[] @relation("VoteOutcomeCreatedItem")

  @@index([tripId, dayIndex])
  @@unique([tripId, dayIndex, sortOrder])
}

// ─── Itinerary Proposals ───────────────────────────

enum ItineraryProposalType {
  ADD_ITEM
  UPDATE_TIME
  UPDATE_LOCATION
  UPDATE_NOTE
}

enum ItineraryProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  OUTDATED
}

model ItineraryProposal {
  id            String                   @id @default(cuid())
  tripId        String
  proposerId    String
  targetItemId  String?
  type          ItineraryProposalType
  payload       Json
  baseVersion   Int?
  status        ItineraryProposalStatus  @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  trip          Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  proposer      User           @relation("ProposalProposer", fields: [proposerId], references: [id])
  reviewer      User?          @relation("ProposalReviewer", fields: [reviewedById], references: [id])
  targetItem    ItineraryItem? @relation("ProposalTargetItem", fields: [targetItemId], references: [id])
  voteOutcomeAsReplacement VoteSessionOutcome[] @relation("VoteOutcomeReplacementProposal")

  @@index([tripId, status])
  @@index([targetItemId])
}

// ─── Voting System ─────────────────────────────────

enum VoteSessionMode {
  NEW_OPTION
  REPLACE_ITEM
  TIE_BREAK
}

enum VoteSessionStatus {
  PENDING_APPROVAL
  OPEN
  CLOSED
  LEADER_DECISION_REQUIRED
}

enum VoteOptionStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  WINNER
  RUNNER_UP
}

model VoteSession {
  id                       String            @id @default(cuid())
  tripId                   String
  createdById              String
  targetItemId             String?
  targetDayIndex           Int?
  targetInsertAfterItemId  String?
  mode                     VoteSessionMode
  status                   VoteSessionStatus @default(PENDING_APPROVAL)
  deadline                 DateTime
  parentSessionId          String?
  approvedById             String?
  tieBreakRound            Int               @default(0)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  trip          Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("VoteSessionCreator", fields: [createdById], references: [id])
  approvedBy    User?          @relation("VoteSessionApprover", fields: [approvedById], references: [id])
  targetItem    ItineraryItem? @relation("VoteSessionTargetItem", fields: [targetItemId], references: [id])
  parentSession VoteSession?   @relation("VoteSessionParentChild", fields: [parentSessionId], references: [id])
  childSessions VoteSession[]  @relation("VoteSessionParentChild")
  options       VoteOption[]
  ballots       VoteBallot[]
  outcome       VoteSessionOutcome?

  @@index([tripId, status])
}

model VoteOption {
  id             String           @id @default(cuid())
  voteSessionId  String
  title          String
  payload        Json
  status         VoteOptionStatus @default(PENDING_APPROVAL)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  voteSession    VoteSession      @relation(fields: [voteSessionId], references: [id], onDelete: Cascade)
  ballots        VoteBallot[]
  winningOutcome VoteSessionOutcome[] @relation("VoteOutcomeWinningOption")

  @@index([voteSessionId])
}

model VoteBallot {
  id             String      @id @default(cuid())
  voteSessionId  String
  userId         String
  voteOptionId   String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  voteSession    VoteSession @relation(fields: [voteSessionId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id])
  voteOption     VoteOption  @relation(fields: [voteOptionId], references: [id])

  @@unique([voteSessionId, userId])
}

model VoteSessionOutcome {
  id                      String    @id @default(cuid())
  voteSessionId           String    @unique
  winningOptionId         String
  tripId                  String
  targetItemId            String?
  targetDayIndex          Int?
  targetInsertAfterItemId String?
  createdItemId           String?
  replacementProposalId   String?
  payload                 Json
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  voteSession         VoteSession        @relation(fields: [voteSessionId], references: [id], onDelete: Cascade)
  winningOption       VoteOption         @relation("VoteOutcomeWinningOption", fields: [winningOptionId], references: [id])
  trip                Trip               @relation(fields: [tripId], references: [id])
  targetItem          ItineraryItem?     @relation("VoteOutcomeTargetItem", fields: [targetItemId], references: [id])
  createdItem         ItineraryItem?     @relation("VoteOutcomeCreatedItem", fields: [createdItemId], references: [id])
  replacementProposal ItineraryProposal? @relation("VoteOutcomeReplacementProposal", fields: [replacementProposalId], references: [id])
}

// ─── Community Templates ───────────────────────────

model CommunityTemplate {
  id                String   @id @default(cuid())
  sourceTripId      String
  publishedById     String
  title             String
  destinationLabel  String
  summary           String?
  coverNote         String?
  daysCount         Int
  cloneCount        Int      @default(0)
  sanitizedSnapshot Json
  status            String   @default("PUBLISHED")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sourceTrip    Trip @relation(fields: [sourceTripId], references: [id])
  publishedBy   User @relation("TemplatePublisher", fields: [publishedById], references: [id])
}

// ─── Logistics: Room & Ride Allocation ─────────────

enum LogisticsUnitType {
  ROOM
  RIDE
}

enum LogisticsRideKind {
  MOTORBIKE
  CAR
  BUS
}

enum LogisticsAssignmentSource {
  LEADER
  SELF_JOIN
  AUTO_FILL
}

model LogisticsUnit {
  id        String             @id @default(cuid())
  tripId    String
  type      LogisticsUnitType
  label     String
  capacity  Int
  rideKind  LogisticsRideKind?
  plateNumber String?
  seatLabels String[]
  sortOrder Int
  note      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  trip        Trip                   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  assignments AllocationAssignment[]

  @@unique([tripId, type, sortOrder])
  @@index([tripId, type])
}

model AllocationAssignment {
  id                    String                     @id @default(cuid())
  tripId                String
  unitId                String
  tripMemberId          String
  seatLabel             String?
  createdByTripMemberId String?
  source                LogisticsAssignmentSource  @default(LEADER)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  unit      LogisticsUnit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  member    TripMember     @relation("AssignedMember", fields: [tripMemberId], references: [id], onDelete: Cascade)
  createdBy TripMember?    @relation("AssignmentCreator", fields: [createdByTripMemberId], references: [id])

  @@unique([unitId, tripMemberId])
  @@index([tripId])
  @@index([tripMemberId])
}

// ─── Logistics: Checklists & Packing ───────────────

enum ChecklistGroupKind {
  SHARED_CATEGORY
  PERSONAL_TASKS
  DOCUMENTS
}

enum ChecklistItemStatus {
  TODO
  DONE
}

model ChecklistGroup {
  id        String             @id @default(cuid())
  tripId    String
  title     String
  kind      ChecklistGroupKind
  sortOrder Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  trip  Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@unique([tripId, kind, sortOrder])
}

model ChecklistItem {
  id                   String              @id @default(cuid())
  tripId               String
  groupId              String
  title                String
  notes                String?
  proofUrl             String?
  proofSubmittedAt     DateTime?
  assigneeTripMemberId String?
  status               ChecklistItemStatus @default(TODO)
  sortOrder            Int
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  trip     Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  group    ChecklistGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignee TripMember?     @relation("AssignedChecklistItems", fields: [assigneeTripMemberId], references: [id])

  @@index([tripId, status])
  @@unique([groupId, sortOrder])
}

// ─── Logistics: Attendance ───────────────────────────

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceLocationStatus {
  GRANTED
  DENIED
  UNAVAILABLE
}

model AttendanceSession {
  id                    String                  @id @default(cuid())
  tripId                String
  createdByTripMemberId String
  title                 String
  meetingLabel          String
  meetingAddress        String
  lat                   Float?
  lng                   Float?
  opensAt               DateTime
  closesAt              DateTime
  status                AttendanceSessionStatus @default(OPEN)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  trip          Trip                   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy     TripMember             @relation("AttendanceSessionCreator", fields: [createdByTripMemberId], references: [id], onDelete: Cascade)
  submissions   AttendanceSubmission[]

  @@index([tripId, status])
}

model AttendanceSubmission {
  id             String                   @id @default(cuid())
  sessionId      String
  tripMemberId   String
  photoUrl       String?
  submittedAt    DateTime                 @default(now())
  lat            Float?
  lng            Float?
  accuracyMeters Float?
  locationStatus AttendanceLocationStatus @default(UNAVAILABLE)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  session        AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member         TripMember        @relation("AttendanceSubmissionMember", fields: [tripMemberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, tripMemberId])
}

// ─── Finance & Safety ───────────────────────────────

enum FundContributionMethod {
  MOMO
  BANK_TRANSFER
  CASH
  OTHER
}

enum FundContributionStatus {
  PLEDGED
  CONFIRMED
  REJECTED
}

enum FundExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  TICKETS
  EMERGENCY
  OTHER
}

model TripFund {
  id                String   @id @default(cuid())
  tripId            String   @unique
  ownerTripMemberId String
  targetAmount      Decimal  @db.Decimal(12,2)
  currency          String   @default("VND")
  momoQrPayload     Json?
  bankQrPayload     Json?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  trip           Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  owner          TripMember          @relation("TripFundOwner", fields: [ownerTripMemberId], references: [id])
  contributions  FundContribution[]
  expenses       FundExpense[]
}

model FundContribution {
  id                  String                 @id @default(cuid())
  tripFundId          String
  tripId              String
  tripMemberId        String
  declaredAmount      Decimal                @db.Decimal(12,2)
  method              FundContributionMethod
  status              FundContributionStatus @default(PLEDGED)
  transferNote        String?
  confirmedByMemberId String?
  confirmedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  trip           Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripFund       TripFund   @relation(fields: [tripFundId], references: [id], onDelete: Cascade)
  member         TripMember @relation("FundContributionMember", fields: [tripMemberId], references: [id], onDelete: Cascade)
  confirmedBy    TripMember? @relation("FundContributionConfirmer", fields: [confirmedByMemberId], references: [id])

  @@index([tripFundId, status])
  @@index([tripId, tripMemberId])
}

model FundExpense {
  id                    String              @id @default(cuid())
  tripFundId            String
  tripId                String
  createdByTripMemberId String
  title                 String
  amount                Decimal             @db.Decimal(12,2)
  category              FundExpenseCategory
  linkedItineraryItemId String?
  incurredAt            DateTime
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripFund   TripFund   @relation(fields: [tripFundId], references: [id], onDelete: Cascade)
  createdBy  TripMember @relation("FundExpenseCreator", fields: [createdByTripMemberId], references: [id], onDelete: Cascade)

  @@index([tripFundId, incurredAt])
  @@index([tripId, category])
}

model SafetyDirectoryEntry {
  id         String   @id @default(cuid())
  tripId      String?
  kind        String
  title       String
  phone       String?
  address     String
  lat         Float?
  lng         Float?
  source      String
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, kind])
}

model SafetyAlert {
  id                       String   @id @default(cuid())
  tripId                   String
  type                     String
  status                   String   @default("OPEN")
  message                  String
  createdByTripMemberId    String?
  linkedItineraryItemId    String?
  acknowledgedByTripMemberId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  trip            Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy       TripMember? @relation("SafetyAlertCreator", fields: [createdByTripMemberId], references: [id])
  acknowledgedBy  TripMember? @relation("SafetyAlertAcknowledger", fields: [acknowledgedByTripMemberId], references: [id])

  @@index([tripId, status])
}

model DailyPodcastRecap {
  id              String   @id @default(cuid())
  tripId          String
  dayIndex        Int
  title           String
  recapText       String
  transcript      String
  audioMode       String   @default("BROWSER_TTS")
  audioUrl        String?
  durationSeconds Int
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, dayIndex])
}
